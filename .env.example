# Cloudflare Configuration
# Copy this file to .env and fill in your actual values

# Your Cloudflare Zone ID (found in your domain's overview page)
VITE_CLOUDFLARE_ZONE_ID=your_zone_id_here

# Your Cloudflare API Token (create one with Zone:Zone:Read and Zone:Analytics:Read permissions)
VITE_CLOUDFLARE_API_TOKEN=your_api_token_here

# Your Cloudflare account email (optional)
VITE_CLOUDFLARE_EMAIL=your_email@example.com

# Development Server Configuration
# Comma-separated list of allowed hosts for external access
VITE_ALLOWED_HOSTS=localhost,127.0.0.1

# Development server port (default: 3000)
VITE_PORT=3000

# Enable external host access (default: true)
VITE_HOST=true